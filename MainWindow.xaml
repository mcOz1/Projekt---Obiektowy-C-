<Window x:Class="WpfApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RPG Inventory &amp; Crafting Simulator" Height="600" Width="800">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <GroupBox Header="1. Blacksmith &amp; Alchemy (Create)" Grid.Column="0" Margin="0,0,10,0">
            <StackPanel Margin="5">
                <TextBlock Text="Item Name:" Margin="0,5,0,2"/>
                <TextBox Name="InputNameTextBox" Margin="0,0,0,10"/>

                <TextBlock Text="Power / Damage:" Margin="0,0,0,2"/>
                <TextBox Name="InputPowerTextBox" Margin="0,0,0,10"/>

                <TextBlock Text="Item Type:" Margin="0,0,0,2"/>
                <ComboBox Name="ItemTypeComboBox" SelectedIndex="0" Margin="0,0,0,15">
                    <ComboBoxItem Content="Potion (Alchemy)"/>
                    <ComboBoxItem Content="Weapon (Blacksmith)"/>
                </ComboBox>

                <Button Content="Craft &amp; Add to Inventory" Click="CreateItem_Click" Padding="5" FontWeight="Bold"/>

                <Separator Margin="0,15,0,15"/>

                <Button Content="Auto-Load Starter Pack (Async)" Click="LoadInventory_Click" Padding="5"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Header="2. Hero's Backpack" Grid.Column="1" Margin="0,0,10,0">
            <Grid Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <ListBox Name="InventoryListBox" Grid.Row="0" SelectionMode="Multiple" DisplayMemberPath="DisplayInfo"/>

                <Button Content="Combine Selected Potions (+)" Grid.Row="1" Click="CombinePotions_Click" Margin="0,10,0,5" Padding="5"/>
                <Button Content="Inspect Selected Item (Reflection)" Grid.Row="2" Click="Reflection_Click" Padding="5"/>
            </Grid>
        </GroupBox>

        <GroupBox Header="3. Adventure Log" Grid.Column="2">
            <TextBox Name="OutputTextBox" AcceptsReturn="True" 
                     VerticalScrollBarVisibility="Auto" IsReadOnly="True" FontFamily="Consolas" Margin="5" Background="#1E1E1E" Foreground="#D4D4D4"/>
        </GroupBox>
    </Grid>
</Window>